# =========================
# Python cache / bytecode
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/

# =========================
# Environment / secrets
# =========================
.env
.env.*
!.env.example

# =========================
# Testing / coverage / tooling
# =========================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# =========================
# Build / packaging
# =========================
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# =========================
# Database / local app state
# =========================
*.db
*.sqlite
*.sqlite3

# =========================
# Logs
# =========================
logs/
*.log

# =========================
# Editor / OS files
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db

# =========================
# Leftover frontend / Node junk
# (safe to keep ignored even after deletion)
# =========================
node_modules/
.tanstack/
.nitro/
.output/
.vinxi/
dist-ssr/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*